# sub_test 全量 + 本地模型（vLLM，需 py311 等 Python>=3.10 且 pip install vllm）
# 选卡：CUDA_VISIBLE_DEVICES=0  多卡并行：CUDA_VISIBLE_DEVICES=0,1,2 --tensor-parallel-size 3
MODEL=~/lzh/Qwen2.5-Coder-7B-Instruct

# conda activate py311
# export CUDA_VISIBLE_DEVICES=0

for f in datasets/xcodeeval/sub_test/LLVMIR.jsonl; do
  echo "=== EVAL $f ==="
  python datasets/xcodeeval/eval.py \
    --data "$f" \
    --model-type local \
    --model "$MODEL" \
    --paradigm direct \
    --llm-timeout 600 \
    --resume
done

# 结果目录: results/local_Qwen2___5-Coder-3B-Instruct/<语言>/*.txt

