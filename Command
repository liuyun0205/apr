# ---------- 训练（推荐：1×vLLM 批量推理 + HF LoRA 训 solver）----------
# 7 卡物理 1-7（不用 GPU0）：
#   CUDA_VISIBLE_DEVICES=1,2,3,4,5,6,7
#   vLLM tp 须整除 28（1/2/4/7），不能用 6
#   推荐：cuda:0-3 → vLLM(tp=4)，cuda:6 → solver 训练（物理卡 7）
#
# 依赖：pip install vllm peft torch transformers

cd ~/lzh/apr

# APPS
CUDA_VISIBLE_DEVICES=1,2,3,4,5,6,7 python model/train.py \
  --dataset apps \
  --dataset_path ~/lzh/datasets/APPS/train \
  --model_path ~/lzh/Qwen2.5-Coder-7B-Instruct \
  --chat_backend vllm \
  --vllm_tp_size 4 \
  --devices cuda:6 \
  --use_lora \
  --gradient_checkpointing \
  --inject_mode half \
  --inject_value 10 \
  --exec_timeout 30 \
  --exec_workers 8 \
  --output_dir outputs/solver_rl \
  --naive_bestofn 3 \
  --solver_bestofn 3 \
  --input_count 10 \
  --input_source input_output \
  --start 0 --end 5000 \
  --epochs 1 \
  --save_every 50 \
  --val_size 300 \
  --val_every 25 \
  --val_seed 42

# 验证集：启动时从 APPS 抽 300 题（有 input_output）→ output_dir/val_indices.json
# 每 25 step 验证：mean_reward；pass@1=另生成 1 份 solver 对 GT；bestofn_pass=原 bestofN 任一全过

# 执行测例说明：
#   --exec_timeout 30      单次子进程最多 30s（默认 10，慢题可加大）
#   --inject_mode half     超时后缩小 random 上界再试（naive 暴力常见）
#   --no_inject_backoff    调试：超时直接失败，不打「注入退避」、不 retry

